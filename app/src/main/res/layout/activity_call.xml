<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/primary"
    android:gravity="center">

    <!-- Recording Indicator -->
    <LinearLayout android:id="@+id/recordingIndicator"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:gravity="center_vertical" android:orientation="horizontal"
        android:background="#33FFFFFF" android:paddingStart="12dp" android:paddingEnd="12dp"
        android:paddingTop="4dp" android:paddingBottom="4dp"
        android:layout_marginBottom="16dp" android:visibility="gone">
        <View android:layout_width="8dp" android:layout_height="8dp"
            android:background="@drawable/dot_red" android:layout_marginEnd="6dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Recording" android:textColor="#FFFFFF" android:textSize="12sp" />
    </LinearLayout>

    <!-- Caller Info -->
    <ImageView android:layout_width="80dp" android:layout_height="80dp"
        android:src="@drawable/circle_gray" android:layout_marginBottom="12dp"
        android:padding="20dp" />

    <TextView android:id="@+id/tvNumber"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Unknown" android:textColor="#FFFFFF"
        android:textSize="26sp" android:textStyle="bold" android:layout_marginBottom="8dp" />

    <TextView android:id="@+id/tvDuration"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="00:00" android:textColor="#CCFFFFFF"
        android:textSize="16sp" android:layout_marginBottom="32dp" />

    <!-- Action Buttons -->
    <GridLayout android:layout_width="280dp" android:layout_height="wrap_content"
        android:columnCount="3" android:layout_marginBottom="24dp">

        <!-- Mute -->
        <LinearLayout android:layout_width="80dp" android:layout_height="80dp"
            android:gravity="center" android:orientation="vertical">
            <ImageButton android:id="@+id/btnMute"
                android:layout_width="52dp" android:layout_height="52dp"
                android:background="@drawable/circle_gray" android:alpha="0.5f"
                android:src="@drawable/ic_mic_off" android:padding="14dp" />
            <TextView android:id="@+id/tvMuteLabel"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Mute" android:textColor="#CCFFFFFF" android:textSize="11sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Speaker -->
        <LinearLayout android:layout_width="80dp" android:layout_height="80dp"
            android:gravity="center" android:orientation="vertical">
            <ImageButton android:id="@+id/btnSpeaker"
                android:layout_width="52dp" android:layout_height="52dp"
                android:background="@drawable/circle_gray" android:alpha="0.5f"
                android:src="@drawable/ic_speaker" android:padding="14dp" />
            <TextView android:id="@+id/tvSpeakerLabel"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Speaker" android:textColor="#CCFFFFFF" android:textSize="11sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Hold -->
        <LinearLayout android:layout_width="80dp" android:layout_height="80dp"
            android:gravity="center" android:orientation="vertical">
            <ImageButton android:id="@+id/btnHold"
                android:layout_width="52dp" android:layout_height="52dp"
                android:background="@drawable/circle_gray" android:alpha="0.5f"
                android:src="@drawable/ic_hold" android:padding="14dp" />
            <TextView android:id="@+id/tvHoldLabel"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Hold" android:textColor="#CCFFFFFF" android:textSize="11sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Record -->
        <LinearLayout android:layout_width="80dp" android:layout_height="80dp"
            android:gravity="center" android:orientation="vertical">
            <ImageButton android:id="@+id/btnRecord"
                android:layout_width="52dp" android:layout_height="52dp"
                android:background="@drawable/circle_gray" android:alpha="0.5f"
                android:src="@drawable/ic_recording" android:padding="14dp" />
            <TextView android:id="@+id/tvRecordLabel"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Record" android:textColor="#CCFFFFFF" android:textSize="11sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Dialpad toggle -->
        <LinearLayout android:layout_width="80dp" android:layout_height="80dp"
            android:gravity="center" android:orientation="vertical">
            <ImageButton android:id="@+id/btnDialpad"
                android:layout_width="52dp" android:layout_height="52dp"
                android:background="@drawable/circle_gray" android:alpha="0.5f"
                android:src="@drawable/ic_dialpad" android:padding="14dp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Dialpad" android:textColor="#CCFFFFFF" android:textSize="11sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Empty slot -->
        <View android:layout_width="80dp" android:layout_height="80dp" />

    </GridLayout>

    <!-- DTMF Dialpad (hidden by default) -->
    <LinearLayout android:id="@+id/dialpadSection"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:orientation="vertical" android:gravity="center"
        android:visibility="gone" android:layout_marginBottom="16dp">

        <TextView android:id="@+id/tvDtmfInput"
            android:layout_width="200dp" android:layout_height="wrap_content"
            android:gravity="center" android:textColor="#FFFFFF" android:textSize="20sp"
            android:layout_marginBottom="8dp" android:minHeight="32dp" />

        <GridLayout android:layout_width="210dp" android:layout_height="wrap_content"
            android:columnCount="3">
            <com.google.android.material.button.MaterialButton android:id="@+id/dtmf1"
                style="@style/MiniDialpadKey" android:text="1"/>
            <com.google.android.material.button.MaterialButton android:id="@+id/dtmf2"
                style="@style/MiniDialpadKey" android:text="2"/>
            <com.google.android.material.button.MaterialButton android:id="@+id/dtmf3"
                style="@style/MiniDialpadKey" android:text="3"/>
            <com.google.android.material.button.MaterialButton android:id="@+id/dtmf4"
                style="@style/MiniDialpadKey" android:text="4"/>
            <com.google.android.material.button.MaterialButton android:id="@+id/dtmf5"
                style="@style/MiniDialpadKey" android:text="5"/>
            <com.google.android.material.button.MaterialButton android:id="@+id/dtmf6"
                style="@style/MiniDialpadKey" android:text="6"/>
            <com.google.android.material.button.MaterialButton android:id="@+id/dtmf7"
                style="@style/MiniDialpadKey" android:text="7"/>
            <com.google.android.material.button.MaterialButton android:id="@+id/dtmf8"
                style="@style/MiniDialpadKey" android:text="8"/>
            <com.google.android.material.button.MaterialButton android:id="@+id/dtmf9"
                style="@style/MiniDialpadKey" android:text="9"/>
            <com.google.android.material.button.MaterialButton android:id="@+id/dtmfStar"
                style="@style/MiniDialpadKey" android:text="*"/>
            <com.google.android.material.button.MaterialButton android:id="@+id/dtmf0"
                style="@style/MiniDialpadKey" android:text="0"/>
            <com.google.android.material.button.MaterialButton android:id="@+id/dtmfHash"
                style="@style/MiniDialpadKey" android:text="#"/>
        </GridLayout>
    </LinearLayout>

    <!-- End Call Button -->
    <ImageButton android:id="@+id/btnEndCall"
        android:layout_width="68dp" android:layout_height="68dp"
        android:background="@drawable/circle_red"
        android:src="@drawable/ic_call_end"
        android:padding="16dp" android:elevation="4dp" />

    <View android:layout_width="match_parent" android:layout_height="24dp" />
</LinearLayout>