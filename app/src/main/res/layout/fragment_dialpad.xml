<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    android:gravity="center">

    <!-- Number Display -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:gravity="center_vertical" android:paddingStart="32dp" android:paddingEnd="16dp"
        android:paddingTop="24dp" android:paddingBottom="16dp">
        <EditText android:id="@+id/etNumber"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@null" android:cursorVisible="false"
            android:focusable="false"
            android:gravity="center" android:hint="Enter number"
            android:textSize="32sp" android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary" android:inputType="phone" />
        <ImageButton android:id="@+id/btnBackspace"
            android:layout_width="48dp" android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_dialpad" android:padding="12dp" />
    </LinearLayout>

    <!-- Dialpad Grid -->
    <GridLayout android:layout_width="280dp" android:layout_height="wrap_content"
        android:columnCount="3" android:rowCount="4"
        android:layout_marginBottom="16dp">

        <com.google.android.material.button.MaterialButton android:id="@+id/btn1"
            style="@style/DialpadKey" android:text="1" android:layout_width="80dp" android:layout_height="80dp"/>
        <com.google.android.material.button.MaterialButton android:id="@+id/btn2"
            style="@style/DialpadKey" android:text="2" android:layout_width="80dp" android:layout_height="80dp"/>
        <com.google.android.material.button.MaterialButton android:id="@+id/btn3"
            style="@style/DialpadKey" android:text="3" android:layout_width="80dp" android:layout_height="80dp"/>
        <com.google.android.material.button.MaterialButton android:id="@+id/btn4"
            style="@style/DialpadKey" android:text="4" android:layout_width="80dp" android:layout_height="80dp"/>
        <com.google.android.material.button.MaterialButton android:id="@+id/btn5"
            style="@style/DialpadKey" android:text="5" android:layout_width="80dp" android:layout_height="80dp"/>
        <com.google.android.material.button.MaterialButton android:id="@+id/btn6"
            style="@style/DialpadKey" android:text="6" android:layout_width="80dp" android:layout_height="80dp"/>
        <com.google.android.material.button.MaterialButton android:id="@+id/btn7"
            style="@style/DialpadKey" android:text="7" android:layout_width="80dp" android:layout_height="80dp"/>
        <com.google.android.material.button.MaterialButton android:id="@+id/btn8"
            style="@style/DialpadKey" android:text="8" android:layout_width="80dp" android:layout_height="80dp"/>
        <com.google.android.material.button.MaterialButton android:id="@+id/btn9"
            style="@style/DialpadKey" android:text="9" android:layout_width="80dp" android:layout_height="80dp"/>
        <com.google.android.material.button.MaterialButton android:id="@+id/btnStar"
            style="@style/DialpadKey" android:text="*" android:layout_width="80dp" android:layout_height="80dp"/>
        <com.google.android.material.button.MaterialButton android:id="@+id/btn0"
            style="@style/DialpadKey" android:text="0" android:layout_width="80dp" android:layout_height="80dp"/>
        <com.google.android.material.button.MaterialButton android:id="@+id/btnHash"
            style="@style/DialpadKey" android:text="#" android:layout_width="80dp" android:layout_height="80dp"/>

    </GridLayout>

    <!-- Call Button -->
    <ImageButton android:id="@+id/btnCall"
        android:layout_width="68dp" android:layout_height="68dp"
        android:background="@drawable/circle_green"
        android:src="@drawable/ic_call"
        android:padding="16dp"
        android:elevation="4dp" />

    <View android:layout_width="match_parent" android:layout_height="24dp" />

</LinearLayout>